# ───────────────────────────────────────────────────────────────────────────────
#  DataTradingPro — Modèle de configuration (.env)
#  Copiez ce fichier en `.env` puis remplissez les valeurs.
#  ⚠ Le vrai `.env` n'est JAMAIS commité (cf .gitignore : .env, .env.*).
#
#  Ce dépôt contient TOUT le CODE et tous les PROMPTS IA → ils se restaurent par un
#  simple `git clone`. Seules les CLÉS/MOTS DE PASSE ci-dessous manquent : ils vivent
#  uniquement ici (et dans votre gestionnaire de secrets / dashboard d'hébergeur).
#  Voir RESTORE.md pour la procédure complète de restauration sur un serveur Linux.
# ───────────────────────────────────────────────────────────────────────────────

# ── Cœur serveur ──────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
SESSION_SECRET=                      # longue chaîne aléatoire : openssl rand -hex 32
ALLOWED_ORIGINS=https://desk.datatradingpro.com,https://datatradingpro.com
APP_URL=https://desk.datatradingpro.com

# ── Supabase — OBLIGATOIRE (auth utilisateurs + cache IA durable `ai_cache`) ───
# Sans ça : pas d'authentification ni de persistance du cache IA (tout serait régénéré
# à chaque redémarrage et brûlerait le quota Gemini). Réutiliser le MÊME projet Supabase
# = retrouver instantanément utilisateurs + cache. Schéma minimal : voir RESTORE.md.
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_KEY=                        # clé service_role

# ── IA — Gemini (moteur principal, free-tier à quota DUR) ─────────────────────
GEMINI_API_KEY=                      # clé Google AI Studio  (sinon GOOGLE_API_KEY)
# GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_RPM=                          # plafond requêtes/min (optionnel)
GEMINI_MONTHLY_BUDGET=               # budget mensuel de requêtes (optionnel)
GEMINI_DAILY_MIN=
GEMINI_DAILY_MAX=
GEMINI_BURST=

# ── IA — Claude / Anthropic (repli multi-clés) ────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_API_KEY2=
ANTHROPIC_API_KEY3=
ANTHROPIC_API_KEY4=
CLAUDE_MODEL=
CLAUDE_DAILY_MAX=

# ── IA — GitHub Models (repli optionnel) ──────────────────────────────────────
GITHUB_TOKEN=
GITHUB_MODEL=
GITHUB_MODELS_URL=

# ── IA — réglages génériques ──────────────────────────────────────────────────
AI_SYSTEM_PROMPT=
AI_QUIET_START=21                    # heures creuses : pas de génération de fond
AI_QUIET_END=7
AI_TAG_DAILY_MAX=
AI_ANALYSE_DAILY_MAX=

# ── Sources de données (scrapers Puppeteer / Chromium) ────────────────────────
FJ_EMAIL=                            # FinancialJuice (flux news temps réel)
FJ_PASS=
MFB_EMAIL=                           # Myfxbook (sentiment retail)
MFB_PASS=
DISABLE_MYFXBOOK=                    # "1" pour désactiver myfxbook
PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
# CHROME_EXEC=

# ── Abonnements (Whop) ────────────────────────────────────────────────────────
WHOP_API_KEY=
WHOP_PRODUCT_ID=
WHOP_WEBHOOK_SECRET=
WHOP_RENEW_URL=
PRICE_MONTHLY=24.99
PRICE_ANNUAL=

# ── E-mails transactionnels (configurer AU MOINS un fournisseur) ──────────────
EMAIL_FROM=
SUPPORT_EMAIL=
RESEND_API_KEY=
MAILJET_API_KEY=
MAILJET_SECRET_KEY=
GMAIL_USER=
GMAIL_APP_PASSWORD=
GMAIL_OAUTH_CLIENT_ID=
GMAIL_OAUTH_CLIENT_SECRET=
GMAIL_OAUTH_REFRESH_TOKEN=
OVH_SMTP_HOST=
OVH_SMTP_PORT=
OVH_SMTP_USER=
OVH_SMTP_PASS=
MAIL_ALLOW_THIRDPARTY=
