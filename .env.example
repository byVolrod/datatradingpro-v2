# ─── Modèle de configuration — copiez ce fichier en `.env` et remplissez ───
# (Le vrai .env ne doit JAMAIS être commité — il est dans .gitignore)

# Environnement
NODE_ENV=development
PORT=3000
SESSION_SECRET=changez-moi-par-une-longue-chaine-aleatoire
# Domaines autorisés en prod (séparés par des virgules) :
ALLOWED_ORIGINS=

# Supabase (authentification / utilisateurs)
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_KEY=eyJ...   # clé service_role

# FinancialJuice (flux news temps réel)
FJ_EMAIL=
FJ_PASS=

# Myfxbook (cotations)
MFB_EMAIL=
MFB_PASS=

# Anthropic / Claude (génération IA des briefings) — optionnel
ANTHROPIC_API_KEY=

# Puppeteer — chemin Chromium (auto-résolu ; à forcer sur certains hôtes)
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
